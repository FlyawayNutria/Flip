// =========================================================
// INTERRUPT & SENSOR FUNCTIONS
// =========================================================
bool TimerHandler(void * timerNo) {
  static bool toggle = false;
  step1.runStepper();
  step2.runStepper();
  digitalWrite(TOGGLE_PIN, toggle);  
  toggle = !toggle;
  return true;
}

uint16_t readADC(uint8_t channel) {
  uint8_t tx0 = 0x06 | (channel >> 2);  
  uint8_t tx1 = (channel & 0x03) << 6;  
  digitalWrite(ADC_CS_PIN, LOW); 
  SPI.transfer(tx0);                    
  uint8_t rx0 = SPI.transfer(tx1);      
  uint8_t rx1 = SPI.transfer(0x00);     
  digitalWrite(ADC_CS_PIN, HIGH); 
  uint16_t result = ((rx0 & 0x0F) << 8) | rx1; 
  return result;
}

// =========================================================
// SETUP
// =========================================================
void setup()
{
  Serial.begin(115200);
  pinMode(TOGGLE_PIN, OUTPUT);

  if (!mpu.begin()) {
    Serial.println("Failed to find MPU6050 chip");
    while (1) delay(10);
  }
  Serial.println("MPU6050 Found!");

  mpu.setAccelerometerRange(MPU6050_RANGE_2_G);
  mpu.setGyroRange(MPU6050_RANGE_250_DEG);
  mpu.setFilterBandwidth(MPU6050_BAND_44_HZ);

  // --- WIFI & WEBSERVER SETUP ---
  Serial.print("Connecting to Wi-Fi");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\n--- WIFI CONNECTED ---");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  server.on("/", []() {
    server.send(200, "text/html", getWebPage());
  });

  server.on("/update", []() {
    if (server.hasArg("p")) Kp = server.arg("p").toFloat();
    if (server.hasArg("i")) Ki = server.arg("i").toFloat();
    if (server.hasArg("d")) Kd = server.arg("d").toFloat();
    if (server.hasArg("t")) setpoint = server.arg("t").toFloat();
    error_integral = 0.0; // Reset history cleanly
    Serial.printf(">>> WEB UPDATE | Kp: %.2f | Ki: %.2f | Kd: %.2f | Setpoint: %.2f\n", Kp, Ki, Kd, setpoint);
    server.send(200, "text/html", getWebPage());
  });

  server.on("/stop", []() {
    robot_active = false;
    digitalWrite(STEPPER_EN_PIN, HIGH);
    integrated_velocity = 0.0;
    error_integral = 0.0;
    Serial.println(">>> WEB COMMAND: EMERGENCY STOP");
    server.send(200, "text/html", getWebPage());
  });

  server.begin();

  // --- STEPPER SETUP ---
  if (!ITimer.attachInterruptInterval(STEPPER_INTERVAL_US, TimerHandler)) {
    Serial.println("Failed to start stepper interrupt");
    while (1) delay(10);
  }
  Serial.println("Initialised Interrupt for Stepper");

  step1.setAccelerationRad(2000.0); 
  step2.setAccelerationRad(2000.0);

  pinMode(STEPPER_EN_PIN, OUTPUT);
  digitalWrite(STEPPER_EN_PIN, false);

  pinMode(ADC_CS_PIN, OUTPUT);
  digitalWrite(ADC_CS_PIN, HIGH);
  SPI.begin(ADC_SCK_PIN, ADC_MISO_PIN, ADC_MOSI_PIN);
}

// =========================================================
// MAIN LOOP
// =========================================================
void loop()
{
  static unsigned long printTimer = 0;  
  static unsigned long loopTimer = 0;   
  static float tiltx = 0.0;  

 // --- 1. SENSOR & BALANCING BLOCK (100Hz) ---
  if (millis() > loopTimer) {
    loopTimer += LOOP_INTERVAL;
    
    sensors_event_t a, g, temp;
    mpu.getEvent(&a, &g, &temp);

    float accel_tilt = atan2(a.acceleration.x, a.acceleration.z)*180.0/PI;
    float gyro_tilt = -g.gyro.y * 180.0/PI;
    
    tiltx = (1.0-C)*accel_tilt + C*(tiltx + gyro_tilt * DT);
    float error = tiltx - setpoint;
    
    // ----------------------------------------------------
    // PHASE A: SAFETY SHUTDOWN
    // ----------------------------------------------------
    if (abs(error) > 30.0 && robot_active) { 
      robot_active = false;
      digitalWrite(STEPPER_EN_PIN, HIGH);
      
      // Wipe everything immediately
      integrated_velocity = 0.0;
      error_integral = 0.0;
      error_old = 0.0;
      step1.setTargetSpeedRad(0.0);
      step2.setTargetSpeedRad(0.0);
    } 
    
    // ----------------------------------------------------
    // PHASE B: LAUNCH GUARD (ARMING)
    // ----------------------------------------------------
    if (!robot_active) {
      if (abs(error) < 0.5) { 
        // We hit the center point! Arm the system.
        robot_active = true;
        digitalWrite(STEPPER_EN_PIN, LOW); // Physical coils energize (You will feel the "Snap")
        
        // Prep the math for a perfectly smooth first calculation
        integrated_velocity = 0.0;
        error_integral = 0.0;
        error_old = error; 
        
        Serial.println(">>> Robot armed");
      } else {
        // Keep library speed at 0 while waiting so it doesn't wind up
        step1.setTargetSpeedRad(0.0);
        step2.setTargetSpeedRad(0.0);
      }
    } 
    
    // ----------------------------------------------------
    // PHASE C: ACTIVE BALANCING
    // Notice this is NOT an "else" statement anymore! 
    // If Phase B just armed the robot, it immediately flows into this math.
    // ----------------------------------------------------
    if (robot_active) {
      error_integral += error * DT;
      error_integral = constrain(error_integral, -MAX_INTEGRAL, MAX_INTEGRAL);

      float error_derivative = (error - error_old) / DT;
      error_old = error;

      float target_accel = Kp*error + Ki*error_integral + Kd*error_derivative;
      target_accel = constrain(target_accel, -MAX_ACCEL, MAX_ACCEL);

      integrated_velocity += target_accel * DT;
      integrated_velocity = constrain(integrated_velocity, -MAX_SPEED, MAX_SPEED);

      step1.setTargetSpeedRad(integrated_velocity);
      step2.setTargetSpeedRad(-integrated_velocity);
    }
  }

  // --- 2. WI-FI SERVER LISTENER ---
  server.handleClient();

  // --- 3. USB SERIAL TUNING PARSER (Kept as backup) ---
  if (Serial.available() > 0) {
    char key = tolower(Serial.read()); 
    float val = Serial.parseFloat(); 
    
    while(Serial.available() > 0 && (Serial.peek() == '\n' || Serial.peek() == '\r')) {
      Serial.read();
    }

    if (key == 'p') { Kp = val; Serial.printf(">>> UPDATED Kp to: %.2f\n", Kp); }
    else if (key == 'i') { Ki = val; error_integral = 0.0; Serial.printf(">>> UPDATED Ki to: %.2f\n", Ki); }
    else if (key == 'd') { Kd = val; Serial.printf(">>> UPDATED Kd to: %.2f\n", Kd); }
    else if (key == 't') { setpoint = val; Serial.printf(">>> UPDATED Setpoint to: %.2f\n", setpoint); }
    else if (key == 'v') { Serial.printf(">>> CURRENT | Kp: %.2f | Ki: %.2f | Kd: %.2f | Setpoint: %.2f\n", Kp, Ki, Kd, setpoint); }
    else if (key == 's') { // Manual emergency stop via USB
      robot_active = false;
      digitalWrite(STEPPER_EN_PIN, HIGH);
      integrated_velocity = 0.0;
      error_integral = 0.0;
      Serial.println(">>> MANUAL EMERGENCY STOP ACTIVATED.");
    }
  }
  
  if (millis() > printTimer) {
    printTimer += PRINT_INTERVAL;
    uint16_t rawAdc = readADC(0);
    float voltage = (rawAdc * VREF) / 4095.0;
  }
}
