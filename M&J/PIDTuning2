float tiltx = 0.0;
float error = 0.0;
float accelAngle = 0.0;
float gyroRate = 0.0;
float targetSpeed = 0.0;
float currentVelo = 0.0;
float kp = 2.5;
float ki = 0.0;
float kd = 0.0;
float error_integral = 0.0;
const float setpoint = 82.2; //Setpoint in degrees!
bool botActive = false; //Safety toggle

//Wifi stuff
#include <secrets.h>
