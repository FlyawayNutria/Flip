/*/#include <Arduino.h>
#include <SPI.h>
#include <TimerInterrupt_Generic.h>
#include <step.h>

// ====================================================================
// STATE MACHINE: STRICT ROTATION ALIGNMENT ONLY (NO OVER-CORRECTION)
// ====================================================================
const int NUM_SENSORS = 3;
const int SENSOR_PINS[NUM_SENSORS] = {32, 33, 34};

int rawLeft   = 0;
int rawCenter = 0;
int rawRight  = 0;

const int STEPPER1_DIR_PIN  = 16;
const int STEPPER1_STEP_PIN = 17;
const int STEPPER2_DIR_PIN  = 4;
const int STEPPER2_STEP_PIN = 14;

const int STEPPER_EN_PIN    = 27; 
const int TOGGLE_PIN        = 13; 

const int PRINT_INTERVAL      = 250; 
const int STEPPER_INTERVAL_US = 50; 

// --- CRITICAL SLOW SPEEDS FOR HIGH 65mm WHEEL RESOLUTION ---
const float RUNNING_SPEED_RAD_S  = 1;  // Very slow forward crawl
const float TURNING_SPEED_RAD_S  = 1.28;  // Exceptionally slow, smooth pivot speed

// --- TARGET STRIDES AND THRESHOLDS ---
const int FORWARD_TICK_TARGET    = 100;   // Reduced forward step distance
const int TAPE_THRESHOLD         = 2000;  // Stricter general tape detection edge
const int CENTER_LOCK_THRESHOLD  = 1500;  // Deep center requirement to stop rotating

enum RobotState {
  START_FORWARD,
  MOVING_FORWARD,
  SETTLE_DELAY,
  READ_SENSORS,
  EXECUTE_SLOW_ALIGN,
  LOCKED_ALIGNING
};
RobotState currentState = START_FORWARD;

ESP32Timer ITimer(3);
step step1(STEPPER_INTERVAL_US, STEPPER1_STEP_PIN, STEPPER1_DIR_PIN); 
step step2(STEPPER_INTERVAL_US, STEPPER2_STEP_PIN, STEPPER2_DIR_PIN); 

volatile long global_timer_ticks = 0;
volatile bool tracking_forward_stride = false;

bool TimerHandler(void * timerNo) {
  static bool toggle = false;
  
  step1.runStepper();
  step2.runStepper();
  
  if (tracking_forward_stride) {
    global_timer_ticks++;
  }
  
  digitalWrite(TOGGLE_PIN, toggle);  
  toggle = !toggle;
  return true;
}

void readLineSensors() {
  rawLeft   = analogRead(SENSOR_PINS[0]); 
  rawCenter = analogRead(SENSOR_PINS[1]); 
  rawRight  = analogRead(SENSOR_PINS[2]); 
}

void setup() {
  Serial.begin(115200);
  delay(500); 
  Serial.println("--- BOOTING STRICT ROTATION LINE TRACKER ---");

  pinMode(TOGGLE_PIN, OUTPUT);
  analogReadResolution(12);
  for (int i = 0; i < NUM_SENSORS; i++) {
    pinMode(SENSOR_PINS[i], INPUT);
    analogSetPinAttenuation(SENSOR_PINS[i], ADC_11db);
  }

  // Softened acceleration curves to eliminate rapid directional jerks
  step1.setAccelerationRad(60.0); 
  step2.setAccelerationRad(60.0);

  pinMode(STEPPER_EN_PIN, OUTPUT);
  digitalWrite(STEPPER_EN_PIN, false); 

  if (!ITimer.attachInterruptInterval(STEPPER_INTERVAL_US, TimerHandler)) {
    Serial.println("CRITICAL ERROR: Interrupt Failure!");
    while (1) delay(10);
  }
  Serial.println("SUCCESS: Precision Active.");
}

void loop() {
  static unsigned long printTimer = 0;
  static unsigned long settleTimer = 0;  
  static String turnIntent = "NONE";
  static String lastSearchDirection = "RIGHT"; 
  static int forced_turn_ticks = 0;

  readLineSensors();

  switch (currentState) {
    
    case START_FORWARD:
      noInterrupts();
      global_timer_ticks = 0;
      tracking_forward_stride = true;
      interrupts();

      step1.setTargetSpeedRad(RUNNING_SPEED_RAD_S);
      step2.setTargetSpeedRad(-RUNNING_SPEED_RAD_S); 
      currentState = MOVING_FORWARD;
      break;

    case MOVING_FORWARD:
      if (global_timer_ticks >= FORWARD_TICK_TARGET) {
        noInterrupts();
        tracking_forward_stride = false;
        interrupts();
        
        step1.setTargetSpeedRad(0.0);
        step2.setTargetSpeedRad(0.0);
        
        settleTimer = millis() + 40; 
        currentState = SETTLE_DELAY;
      }
      break;

    case SETTLE_DELAY:
      if (millis() >= settleTimer) {
        currentState = READ_SENSORS;
      }
      break;

    case READ_SENSORS: {
      // Prioritize the center channel exclusively
      if (rawCenter < CENTER_LOCK_THRESHOLD) {
        // Center is already perfectly over the line. Advance!
        turnIntent = "FORWARD";
        currentState = START_FORWARD;
      } 
      else {
        // Center is off the path. Decide rotation side based directly on outer markers
        if (rawLeft < TAPE_THRESHOLD && rawRight >= TAPE_THRESHOLD) {
          turnIntent = "LEFT";
          lastSearchDirection = "LEFT";
        } 
        else if (rawRight < TAPE_THRESHOLD && rawLeft >= TAPE_THRESHOLD) {
          turnIntent = "RIGHT";
          lastSearchDirection = "RIGHT";
        } 
        else {
          // If we lost it or both sides trigger, fall back to our last successful search vector
          turnIntent = lastSearchDirection;
        }
        currentState = EXECUTE_SLOW_ALIGN;
      }
      break;
    }

    case EXECUTE_SLOW_ALIGN:
      noInterrupts();
      global_timer_ticks = 0;
      tracking_forward_stride = true; 
      interrupts();

      // Blind steps window (forces initial breakout from current state)
      forced_turn_ticks = 100; 

      if (turnIntent == "LEFT") { 
        step1.setTargetSpeedRad(-TURNING_SPEED_RAD_S); 
        step2.setTargetSpeedRad(-TURNING_SPEED_RAD_S);  
      } 
      else { // RIGHT
        step1.setTargetSpeedRad(TURNING_SPEED_RAD_S);   
        step2.setTargetSpeedRad(TURNING_SPEED_RAD_S); 
      }
      currentState = LOCKED_ALIGNING;
      break;

    case LOCKED_ALIGNING:
      // STRICT LOCKOUT: Do absolutely nothing except rotate slowly until center hits solid black path
      if (global_timer_ticks >= forced_turn_ticks) {
        if (rawCenter < CENTER_LOCK_THRESHOLD) {
          noInterrupts();
          tracking_forward_stride = false; 
          interrupts();
          
          step1.setTargetSpeedRad(0.0);
          step2.setTargetSpeedRad(0.0);
          
          settleTimer = millis() + 40; // Settle mechanical bounce completely
          currentState = SETTLE_DELAY; 
        }
      }
      break;
  }

  if (millis() > printTimer) {
    printTimer = millis() + PRINT_INTERVAL; 
    Serial.println("\n================================================================================");
    Serial.print("STATE: "); 
    switch(currentState) {
      case START_FORWARD:       Serial.print("START_FORWARD"); break;
      case MOVING_FORWARD:      Serial.print("MOVING_FORWARD (CREEPING)"); break;
      case SETTLE_DELAY:        Serial.print("SETTLE_DELAY"); break;
      case READ_SENSORS:        Serial.print("READ_SENSORS"); break;
      case EXECUTE_SLOW_ALIGN:  Serial.print("EXECUTE_SLOW_ALIGN"); break;
      case LOCKED_ALIGNING:     Serial.print("LOCKED_ALIGNING (SLOW ROTATION TO CENTER)"); break;
    }
    Serial.print(" | VECTOR INTENT: "); Serial.println(turnIntent);
    Serial.print("[LIVE DATA] -> L: "); Serial.print(rawLeft);
    Serial.print(" | C: "); Serial.print(rawCenter);
    Serial.print(" | R: "); Serial.println(rawRight);
    Serial.println("================================================================================");
  }
} /*/

#include <Arduino.h>

// ====================================================================
// CALIBRATED CONFIGURATION FOR 15V POWER + 2.2K RESISTOR HARNESS
// ====================================================================
const int BATTERY_PIN = 35;       

// Real math: (10k + 2.2k) / 2.2k = 5.545
// Hand-tuned slightly to 5.62 to compensate for ESP32 ADC internal drop
const float DIVIDER_RATIO = 5.62; 

// Setup your capacity scale for your 15V main rail
const float MAX_VOLTAGE = 15.0;
const float MIN_VOLTAGE = 0.0;

const unsigned long READ_INTERVAL = 500; 

float getBatteryVoltage() {
  int rawADC = analogRead(BATTERY_PIN);
  
  // Convert 12-bit ADC value (0-4095) to the ESP32's max tolerance of 3.3V
  float pinVoltage = (rawADC / 4095.0) * 3.3;
  
  // Multiply by the new 2.2k scaling ratio to reveal the true rail voltage
  float trueBatteryVoltage = pinVoltage * DIVIDER_RATIO;
  
  return trueBatteryVoltage;
}

int getBatteryPercentage(float voltage) {
  int percentage = (int)(((voltage - MIN_VOLTAGE) / (MAX_VOLTAGE - MIN_VOLTAGE)) * 100.0);
  
  if (percentage > 100) percentage = 100;
  if (percentage < 0)   percentage = 0;
  
  return percentage;
}

void setup() {
  Serial.begin(115200);
  delay(500);
  Serial.println("--- ESP32 15V RESISTOR DIVIDER ONLINE ---");

  analogReadResolution(12);
  analogSetPinAttenuation(BATTERY_PIN, ADC_11db);
  pinMode(BATTERY_PIN, INPUT);
}

void loop() {
  static unsigned long lastReadTime = 0;

  if (millis() - lastReadTime >= READ_INTERVAL) {
    lastReadTime = millis();

    float currentVoltage = getBatteryVoltage();
    int currentPercentage = getBatteryPercentage(currentVoltage);

    Serial.print("Power Rail Status: ");
    Serial.print(currentVoltage, 2); 
    Serial.print("V | Capacity: ");
    Serial.print(currentPercentage);
    Serial.println("%");
  }
}
