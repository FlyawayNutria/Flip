# Install libraries with this command: sudo apt update && sudo apt install python3-opencv python3-flask python3-picamera2 -y
# command to run code: python3 robot_stream.py

import cv2
from flask import Flask, Response, render_template_string
from picamera2 import Picamera2

app = Flask(__name__)
picam2 = Picamera2()

# Optimize resolution for low latency over Wi-Fi
picam2.configure(picam2.create_preview_configuration(main={"format": "XRGB8888", "size": (640, 480)}))
picam2.start()

def generate_frames():
    while True:
        frame = picam2.capture_array()
        # Compress to JPEG to save network bandwidth
        ret, buffer = cv2.imencode('.jpg', frame, [int(cv2.IMWRITE_JPEG_QUALITY), 70])
        if not ret:
            continue
        yield (b'--frame\r\n'
               b'Content-Type: image/jpeg\r\n\r\n' + buffer.tobytes() + b'\r\n')

@app.route('/')
def index():
    return render_template_string("""
        <html>
            <head>
                <title>Robot Live Feed</title>
                <style>
                    body { text-align: center; font-family: Arial; background: #222; color: white; }
                    img { border: 4px solid #555; border-radius: 8px; margin-top: 20px; max-width: 100%; }
                </style>
            </head>
            <body>
                <h1>🤖 Robot Live Vision</h1>
                <img src="{{ url_for('video_feed') }}">
            </body>
        </html>
    """)

@app.route('/video_feed')
def video_feed():
    return Response(generate_frames(), mimetype='multipart/x-mixed-replace; boundary=frame')

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000, threaded=True)
