#include <Arduino.h>
#include <SPI.h>
#include <TimerInterrupt_Generic.h>
#include <Adafruit_MPU6050.h>
#include <Adafruit_Sensor.h>
#include <step.h>

// ====================================================================
// USER CONFIGURATION: CALIBRATION-FREE CENTROID PARAMETERS
// ====================================================================
const String TRACK_LINE_COLOR = "BLACK"; 

// Native ESP32 Analog Input Assignments
const int NUM_SENSORS = 3;
const int SENSOR_PINS[NUM_SENSORS] = {32, 33, 34}; // Left = 32, Center = 33, Right = 34

// Global Sensor Variables
int rawLeft   = 0;  
int rawCenter = 0;  
int rawRight  = 0;  

// PD Steering Tuning constants
float Kp_yaw = 0.35;  // Aggression tracking snap
float Kd_yaw = 0.12;  // Oscillation dampening
float lastError = 0;

// Stepper Driver Pin Assignments
const int STEPPER1_DIR_PIN  = 16;
const int STEPPER1_STEP_PIN = 17;
const int STEPPER2_DIR_PIN  = 4;
const int STEPPER2_STEP_PIN = 14;
const int STEPPER_EN_PIN    = 15; 

// Diagnostic & Timing Constants
const int TOGGLE_PIN        = 25; 
const int PRINT_INTERVAL    = 500;
const int LOOP_INTERVAL     = 10;   // Core control execution loop at 100Hz
const int STEPPER_INTERVAL_US = 20;

const float kx = 20.0;

// Global Objects
ESP32Timer ITimer(3);
Adafruit_MPU6050 mpu; 

step step1(STEPPER_INTERVAL_US, STEPPER1_STEP_PIN, STEPPER1_DIR_PIN);
step step2(STEPPER_INTERVAL_US, STEPPER2_STEP_PIN, STEPPER2_DIR_PIN);

// Forward declaration of functions
float runBalancePID(float tilt);

// Interrupt Service Routine for motor step execution updates
bool TimerHandler(void * timerNo) {
  static bool toggle = false;

  step1.runStepper();
  step2.runStepper();

  digitalWrite(TOGGLE_PIN, toggle);  
  toggle = !toggle;
  return true;
}

// Native direct-read function
void readLineSensors() {
  rawLeft   = analogRead(SENSOR_PINS[0]); 
  rawCenter = analogRead(SENSOR_PINS[1]); 
  rawRight  = analogRead(SENSOR_PINS[2]); 
}

float getSteeringCorrection(float currentError) {
  float P = currentError;
  float D = currentError - lastError;
  lastError = currentError;

  return (P * Kp_yaw) + (D * Kd_yaw);
}

float runBalancePID(float tilt) {
  return tilt * kx;
}

void setup() {
  Serial.begin(115200);
  pinMode(TOGGLE_PIN, OUTPUT);

  // Initialize analog specifications natively on internal pins
  analogReadResolution(12);
  for (int i = 0; i < NUM_SENSORS; i++) {
    pinMode(SENSOR_PINS[i], INPUT);
    analogSetPinAttenuation(SENSOR_PINS[i], ADC_11db);
  }

  if (!mpu.begin()) {
    Serial.println("Failed to find MPU6050 chip");
    while (1) delay(10);
  }
  Serial.println("MPU6050 Found!");

  mpu.setAccelerometerRange(MPU6050_RANGE_2_G);
  mpu.setGyroRange(MPU6050_RANGE_250_DEG);
  mpu.setFilterBandwidth(MPU6050_BAND_44_HZ);

  if (!ITimer.attachInterruptInterval(STEPPER_INTERVAL_US, TimerHandler)) {
    Serial.println("Failed to start stepper interrupt");
    while (1) delay(10);
  }
  Serial.println("Initialised Interrupt for Stepper");

  step1.setAccelerationRad(10.0);
  step2.setAccelerationRad(10.0);

  pinMode(STEPPER_EN_PIN, OUTPUT);
  digitalWrite(STEPPER_EN_PIN, false); // Enable motors

  Serial.println("System Active: Calibration Skipped. Running Real-Time Centroid Logic.");
}

void loop() {
  static unsigned long printTimer = 0;  
  static unsigned long loopTimer = millis(); 
  static float tiltx = 0.0;             

  // Dynamic Multi-Tasking Loop running strictly at 100Hz (Every 10ms)
  if (millis() > loopTimer) {
    loopTimer += LOOP_INTERVAL;
    
    // 1. Fetch IMU Data for Balancing
    sensors_event_t a, g, temp;
    mpu.getEvent(&a, &g, &temp);
    tiltx = a.acceleration.z / 9.67;
    float balanceSpeed = runBalancePID(tiltx);

    // 2. Read Raw Analog Voltages (ESP32 ADC: 0 to 4095)
    readLineSensors();

    // 3. Subtract Ambient Background Noise Floor to isolate tape profile
    // ESP32 ADC reads dark surfaces high. 
    // If white paper outputs ~1000, setting a noise floor of 1500 strips it out completely.
    const int NOISE_FLOOR = 1500; 
    
    float adjLeft   = max(0, rawLeft - NOISE_FLOOR);
    float adjCenter = max(0, rawCenter - NOISE_FLOOR);
    float adjRight  = max(0, rawRight - NOISE_FLOOR);
    
    float totalDarkness = adjLeft + adjCenter + adjRight;

    // 4. Calculate Exact Midpoint Error via Weighted Average Centroid
    float lineError = 0.0;
    float steeringOffset = 0.0;
    String directionArrow = "  [ ? ]  ";
    String logicStatus    = "Tracking Center...";

    // Scenario A: Total darkness signal is too low (All sensors are over White Paper)
    if (totalDarkness < 300) { 
      steeringOffset = 0.0;
      directionArrow = " [LOST] ";
      logicStatus    = "All White Floor - No Line Detected";
      // Clear error history when line is lost to avoid derivative spike on recovery
      lastError = 0; 
    } 
    // Scenario B: Black tape detected! Calculate spatial midpoint balance
    else {
      // Centroid weight distribution mapping: Left is -1000.0, Center is 0.0, Right is 1000.0
      lineError = ((adjLeft * -1000.0) + (adjCenter * 0.0) + (adjRight * 1000.0)) / totalDarkness;
      
      // Compute the PD loop output based on exact offset magnitude
      steeringOffset = getSteeringCorrection(lineError);

      // Determine visual diagnostic indicators based on error scale bounds
      if (lineError < -150.0) {
        directionArrow = "<<< LEFT <<<";
        logicStatus    = "Line shifted Left (Error: " + String(lineError, 1) + ")";
      } 
      else if (lineError > 150.0) {
        directionArrow = ">>> RIGHT >>>";
        logicStatus    = "Line shifted Right (Error: " + String(lineError, 1) + ")";
      } 
      else {
        directionArrow = "^^^ STRAIGHT ^^^";
        logicStatus    = "Centered on Target Midpoint";
      }
    }

    // 5. Actuator Output Mixer Allocation
    float leftMotorTarget  = balanceSpeed + steeringOffset;
    float rightMotorTarget = -balanceSpeed + steeringOffset; 

    // 6. Update Actuator Steps
    step1.setTargetSpeedRad(leftMotorTarget);
    step2.setTargetSpeedRad(rightMotorTarget);
    
    // 7. Print Live Midpoint Telemetry to Serial Monitor (Runs at 2Hz)
    if (millis() > printTimer) {
      printTimer = millis() + PRINT_INTERVAL; 
      
      Serial.println("\n================================================================================");
      Serial.print("DIRECTION: "); 
      Serial.print(directionArrow); 
      Serial.print("  |  STATUS: "); 
      Serial.println(logicStatus);
      
      Serial.print("   [CENTROID DATA] -> ");
      Serial.print("Raw_L:");      Serial.print(rawLeft);       Serial.print(" | ");
      Serial.print("Raw_C:");      Serial.print(rawCenter);     Serial.print(" | ");
      Serial.print("Raw_R:");      Serial.print(rawRight);      Serial.print(" || ");
      Serial.print("Line_Error:"); Serial.println(lineError, 2);
      Serial.println("================================================================================");
    }
  }
}
