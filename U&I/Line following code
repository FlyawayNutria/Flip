#include <Arduino.h>
#include <SPI.h>
#include <TimerInterrupt_Generic.h>
#include <Adafruit_MPU6050.h>
#include <Adafruit_Sensor.h>
#include <step.h>

// Global Sensor Variables
int rawLeft   = 0;  // Reads Left Sensor
int rawCenter = 0;  // Reads Center Sensor
int rawRight  = 0;  // Reads Right Sensor

int floorMax[3] = {0, 0, 0};          // Will store highest values (Dark Floor ~4000)
int tapeMin[3]  = {4095, 4095, 4095}; // Will store lowest values (White Tape ~200)

float normLeft, normCenter, normRight;

// PD Steering Tuning constants
float Kp_yaw = 0.35;  // Adjust how aggressively it snaps back to the line
float Kd_yaw = 0.12;  // Adjust to dampen oscillations (prevents zig-zagging)
float lastError = 0;

// Stepper Driver Pin Assignments
const int STEPPER1_DIR_PIN  = 16;
const int STEPPER1_STEP_PIN = 17;
const int STEPPER2_DIR_PIN  = 4;
const int STEPPER2_STEP_PIN = 14;
const int STEPPER_EN_PIN    = 15; 

// MCP3208 External ADC Pin Assignments
const int ADC_CS_PIN        = 5;
const int ADC_SCK_PIN       = 18;
const int ADC_MISO_PIN      = 19;
const int ADC_MOSI_PIN      = 23;

// Diagnostic & Timing Constants
const int TOGGLE_PIN        = 32; // Pin for oscilloscope monitoring
const int PRINT_INTERVAL    = 500;
const int LOOP_INTERVAL     = 10;   // Runs the core loop at 100Hz
const int STEPPER_INTERVAL_US = 20;

const float kx = 20.0;
const float VREF = 4.096;

// Global Objects
ESP32Timer ITimer(3);
Adafruit_MPU6050 mpu; 

step step1(STEPPER_INTERVAL_US, STEPPER1_STEP_PIN, STEPPER1_DIR_PIN);
step step2(STEPPER_INTERVAL_US, STEPPER2_STEP_PIN, STEPPER2_DIR_PIN);

// Forward declaration of functions
uint16_t readADC(uint8_t channel);
float runBalancePID(float tilt);

// Interrupt Service Routine for motor updates
bool TimerHandler(void * timerNo) {
  static bool toggle = false;

  step1.runStepper();
  step2.runStepper();

  digitalWrite(TOGGLE_PIN, toggle);  
  toggle = !toggle;
  return true;
}

// Fixed SPI Communication Routine for MCP3208
uint16_t readADC(uint8_t channel) {
  uint8_t TX0 = 0x06 | (channel >> 2);          
  uint8_t TX_BYTE1 = (channel & 0x03) << 6;  

  digitalWrite(ADC_CS_PIN, LOW); 

  SPI.transfer(TX0);                                    
  uint8_t RX0 = SPI.transfer(TX_BYTE1);  // Fixed: Changed TX1 to TX_BYTE1
  uint8_t RX_BYTE1 = SPI.transfer(0x00); 

  digitalWrite(ADC_CS_PIN, HIGH); 

  uint16_t result = ((RX0 & 0x0F) << 8) | RX_BYTE1; // Fixed: Changed RX1 to RX_BYTE1
  return result;
}

void readLineSensors() {
  rawLeft   = readADC(0); 
  rawCenter = readADC(1); 
  rawRight  = readADC(2); 
}

void calibrateSensors() {
  Serial.println("Starting Line Sensor Calibration... Sweep over track now!");
  for (int i = 0; i < 400; i++) {
    int currentL = readADC(0);
    int currentC = readADC(1);
    int currentR = readADC(2);

    if (currentL < tapeMin[0]) tapeMin[0] = currentL;
    if (currentC < tapeMin[1]) tapeMin[1] = currentC;
    if (currentR < tapeMin[2]) tapeMin[2] = currentR;

    if (currentL > floorMax[0]) floorMax[0] = currentL;
    if (currentC > floorMax[1]) floorMax[1] = currentC;
    if (currentR > floorMax[2]) floorMax[2] = currentR;
    
    delay(10); 
  }
  Serial.println("Calibration Completed!");
}

void normalizeReadings() {
  int clampedL = constrain(rawLeft, tapeMin[0], floorMax[0]);
  normLeft = map(clampedL, tapeMin[0], floorMax[0], 1000, 0);

  int clampedC = constrain(rawCenter, tapeMin[1], floorMax[1]);
  normCenter = map(clampedC, tapeMin[1], floorMax[1], 1000, 0);

  int clampedR = constrain(rawRight, tapeMin[2], floorMax[2]);
  normRight = map(clampedR, tapeMin[2], floorMax[2], 1000, 0);
}

float calculateLineError() {
  float totalWeight = normLeft + normCenter + normRight;
  
  if (totalWeight < 150) { 
    return 0; 
  }

  float error = ((normLeft * -1000.0) + (normCenter * 0.0) + (normRight * 1000.0)) / totalWeight;
  return error; 
}

float getSteeringCorrection(float currentError) {
  float P = currentError;
  float D = currentError - lastError;
  lastError = currentError;

  return (P * Kp_yaw) + (D * Kd_yaw);
}

// Temporary balancing mock function based on your baseline code
float runBalancePID(float tilt) {
  return tilt * kx;
}

void setup() {
  Serial.begin(115200);
  pinMode(TOGGLE_PIN, OUTPUT);

  if (!mpu.begin()) {
    Serial.println("Failed to find MPU6050 chip");
    while (1) delay(10);
  }
  Serial.println("MPU6050 Found!");

  mpu.setAccelerometerRange(MPU6050_RANGE_2_G);
  mpu.setGyroRange(MPU6050_RANGE_250_DEG);
  mpu.setFilterBandwidth(MPU6050_BAND_44_HZ);

  if (!ITimer.attachInterruptInterval(STEPPER_INTERVAL_US, TimerHandler)) {
    Serial.println("Failed to start stepper interrupt");
    while (1) delay(10);
  }
  Serial.println("Initialised Interrupt for Stepper");

  step1.setAccelerationRad(10.0);
  step2.setAccelerationRad(10.0);

  pinMode(STEPPER_EN_PIN, OUTPUT);
  digitalWrite(STEPPER_EN_PIN, false); // Enable motors

  pinMode(ADC_CS_PIN, OUTPUT);
  digitalWrite(ADC_CS_PIN, HIGH);
  SPI.begin(ADC_SCK_PIN, ADC_MISO_PIN, ADC_MOSI_PIN, ADC_CS_PIN);

  // Run the calibration loop before entry into execution
  calibrateSensors();
}

void loop() {
  static unsigned long printTimer = 0;  
  static unsigned long loopTimer = 0;   
  static float tiltx = 0.0;             

  // Dynamic Multi-Tasking Loop: Runs exactly every 10ms
  if (millis() > loopTimer) {
    loopTimer += LOOP_INTERVAL;
    
    // 1. Fetch IMU Data for Balancing
    sensors_event_t a, g, temp;
    mpu.getEvent(&a, &g, &temp);
    tiltx = a.acceleration.z / 9.67;
    float balanceSpeed = runBalancePID(tiltx);

    // 2. Fetch and Process Line Tracking Sensors
    readLineSensors();
    normalizeReadings();

    float totalBrightness = normLeft + normCenter + normRight;
    float steeringOffset = 0.0;

    // 3. Track End Check: If all dark, clear steering logic and hover balance
    if (totalBrightness < 150) {
      steeringOffset = 0.0; 
    } else {
      // Line is active: compute corrections
      float currentError = calculateLineError(); 
      steeringOffset = getSteeringCorrection(currentError);
    }

    // 4. Mixing Architecture
    // Left and Right signs handle opposed rotation to execute a yaw spin
    float leftMotorTarget  = balanceSpeed + steeringOffset;
    float rightMotorTarget = -balanceSpeed + steeringOffset; 

    // 5. Command Actuators
    step1.setTargetSpeedRad(leftMotorTarget);
    step2.setTargetSpeedRad(rightMotorTarget);
  }
  
  // Clean Diagnostic Output Serial Frame
  if (millis() > printTimer) {
    printTimer += PRINT_INTERVAL;
    Serial.print("Tilt:");   Serial.print(tiltx * 1000);   Serial.print(" ");
    Serial.print("L_Norm:"); Serial.print(normLeft);       Serial.print(" ");
    Serial.print("C_Norm:"); Serial.print(normCenter);     Serial.print(" ");
    Serial.print("R_Norm:"); Serial.print(normRight);      Serial.println();
  }
}
